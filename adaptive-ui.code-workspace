{
	"folders": [
		{
			"path": "."
		},
		{
			"path": "api",
			"name": "api (Azure Functions)"
		}
	],
	"settings": {
		"npm.autoDetect": "off",
		"typescript.tsc.autoDetect": "off"
	},
	"tasks": {
		"version": "2.0.0",
		"tasks": [
			{
				"label": "Doctor",
				"type": "shell",
				"command": "npm run doctor",
				"presentation": {
					"reveal": "always",
					"panel": "shared"
				}
			},
			{
				"label": "Contract",
				"type": "shell",
				"command": "npm run contract",
				"presentation": {
					"reveal": "always",
					"panel": "shared"
				}
			},
			{
				"label": "Build All",
				"type": "shell",
				"command": "node tooling/workspacectl.mjs build",
				"group": {
					"kind": "build",
					"isDefault": true
				},
				"problemMatcher": ["$tsc"],
				"presentation": {
					"reveal": "always",
					"panel": "dedicated"
				}
			},
			{
				"label": "Start: Trip Notebook",
				"type": "shell",
				"command": "node tooling/workspacectl.mjs start trip-notebook",
				"isBackground": true,
				"problemMatcher": {
					"pattern": {
						"regexp": "^$"
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": "^Starting",
						"endsPattern": "Local:\\s+http"
					}
				},
				"presentation": {
					"reveal": "always",
					"panel": "dedicated"
				}
			},
			{
				"label": "Start: Solution Architect",
				"type": "shell",
				"command": "node tooling/workspacectl.mjs start solution-architect",
				"isBackground": true,
				"problemMatcher": {
					"pattern": {
						"regexp": "^$"
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": "^Starting",
						"endsPattern": "Local:\\s+http"
					}
				},
				"presentation": {
					"reveal": "always",
					"panel": "dedicated"
				}
			},
			{
				"label": "Compile: Try AKS",
				"type": "shell",
				"command": "npx tsc -b",
				"options": {
					"cwd": "${workspaceFolder}/demos/adaptive-ui-try-aks"
				},
				"group": "build",
				"problemMatcher": ["$tsc"],
				"presentation": {
					"reveal": "always",
					"panel": "dedicated"
				}
			},
			{
				"label": "Start: Try AKS",
				"type": "shell",
				"command": "node tooling/workspacectl.mjs start try-aks",
				"isBackground": true,
				"problemMatcher": {
					"pattern": {
						"regexp": "^$"
					},
					"background": {
						"activeOnStart": true,
						"beginsPattern": "^Starting",
						"endsPattern": "Local:\\s+http"
					}
				},
				"presentation": {
					"reveal": "always",
					"panel": "dedicated"
				}
			},
			{
				"label": "Release: Patch Dry Run",
				"type": "shell",
				"command": "npm run release -- patch --dry-run",
				"presentation": {
					"reveal": "always",
					"panel": "shared"
				}
			},
			{
				"label": "Sync: Dry Run",
				"type": "shell",
				"command": "npm run sync -- --dry-run --create-pr",
				"presentation": {
					"reveal": "always",
					"panel": "shared"
				}
			},
			{
				"label": "Sync: Create PR",
				"type": "shell",
				"command": "npm run sync -- --create-pr",
				"presentation": {
					"reveal": "always",
					"panel": "shared"
				}
			}
		]
	},
	"launch": {
		"version": "0.2.0",
		"configurations": [
			{
				"name": "Launch: Trip Notebook",
				"type": "chrome",
				"request": "launch",
				"url": "http://localhost:5174",
				"webRoot": "${workspaceFolder}/demos/adaptive-ui-trip-notebook/src",
				"preLaunchTask": "Start: Trip Notebook",
	
			},
			{
				"name": "Launch: Solution Architect",
				"type": "chrome",
				"request": "launch",
				"url": "http://localhost:5174",
				"webRoot": "${workspaceFolder}/demos/adaptive-ui-solution-architect/src",
				"preLaunchTask": "Start: Solution Architect",
				},
			{
				"name": "Launch: Try AKS",
				"type": "chrome",
				"request": "launch",
				"url": "http://localhost:5174",
				"webRoot": "${workspaceFolder}/demos/adaptive-ui-try-aks/src",
				"preLaunchTask": "Start: Try AKS"
			}
		]
	}
}