{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["trip-notebook/*", "solution-architect/*"]
  },
  "routes": [
    {
      "route": "/trip-notebook",
      "redirect": "/trip-notebook/",
      "statusCode": 302
    },
    {
      "route": "/solution-architect",
      "redirect": "/solution-architect/",
      "statusCode": 302
    },
    {
      "route": "/trip-notebook/*",
      "rewrite": "/trip-notebook/index.html"
    },
    {
      "route": "/solution-architect/*",
      "rewrite": "/solution-architect/index.html"
    }
  ]
}
