{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Doctor",
			"type": "shell",
			"command": "npm run doctor",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Contract",
			"type": "shell",
			"command": "npm run contract",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Build All",
			"type": "shell",
			"command": "node tooling/workspacectl.mjs build",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": ["$tsc"],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Start: Trip Notebook",
			"type": "shell",
			"command": "node tooling/workspacectl.mjs start trip-notebook",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^$"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^Starting",
					"endsPattern": "Local:\\s+http"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Start: Try AKS",
			"type": "shell",
			"command": "node tooling/workspacectl.mjs start try-aks",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^$"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^Starting",
					"endsPattern": "Local:\\s+http"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Start: Solution Architect",
			"type": "shell",
			"command": "node tooling/workspacectl.mjs start solution-architect",
			"isBackground": true,
			"problemMatcher": {
				"pattern": {
					"regexp": "^$"
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^Starting",
					"endsPattern": "Local:\\s+http"
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			}
		},
		{
			"label": "Release: Patch Dry Run",
			"type": "shell",
			"command": "npm run release -- patch --dry-run",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Sync: Dry Run",
			"type": "shell",
			"command": "npm run sync -- --dry-run --create-pr",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "Sync: Create PR",
			"type": "shell",
			"command": "npm run sync -- --create-pr",
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		}
	]
}
